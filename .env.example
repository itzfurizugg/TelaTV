# CORS Proxy URL for hls.js stream loading.
# In production (Vercel) this points to the Edge Function.
# In development you can use a public CORS proxy service or run a local proxy.
# Set to empty string to disable proxying entirely.
VITE_CORS_PROXY_URL=/api/stream-proxy

# Example using a public CORS proxy for local dev (uncomment to use):
# VITE_CORS_PROXY_URL=https://corsproxy.io/?
